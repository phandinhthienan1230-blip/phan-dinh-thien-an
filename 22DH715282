import nltk
import re
import string  
# Download required NLTK resources (run once)
nltk.download('punkt')
nltk.download('punkt_tab')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('omw-1.4')

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer

#Input text
text = ("My name is Phan Đình Thiên Ân. I’m 21 years old."
    "My email is phandinhthienan1230@gmail.com."
    "I’m studying English at HUFLIT. English has been my favorite subject since high school."
)
print("ORIGINAL TEXT:\n", text)
print("-" * 60)

#Tokenization
tokens = word_tokenize(text)
print("TOKENS:\n", tokens)
print("-" * 60)

#Lowercasing
lower_tokens = [token.lower() for token in tokens]
print("LOWERCASED TOKENS:\n", lower_tokens) 
print("-" * 60)

#Stopword Removal
stop_words = set(stopwords.words('english'))
filtered_tokens = [token for token in lower_tokens if token not in stop_words]
print("TOKENS AFTER STOPWORD REMOVAL:\n", filtered_tokens)
print("-" * 60)

#Punctuation Removal
punctuation_table = str.maketrans('', '', string.punctuation)
no_punct_tokens = [token.translate(punctuation_table) for token in filtered_tokens if token.translate(punctuation_table)]
print("TOKENS AFTER PUNCTUATION REMOVAL:\n", punctuation_table)
print("-" * 60)

#Stemming
stemmer = PorterStemmer()
stemmed_tokens = [stemmer.stem(token) for token in no_punct_tokens]
print("STEMMED TOKENS:\n", stemmed_tokens)
print("-" * 60)

#Lemmatization
lemmatizer = WordNetLemmatizer()
lemmatized_tokens = [lemmatizer.lemmatize(token) for token in no_punct_tokens]
print("LEMMATIZED TOKENS:\n", lemmatized_tokens)
print("-" * 60)

#Final Output
print("FINAL PROCESSED TOKENS:\n", lemmatized_tokens)
print("-" * 60)
print("Total tokens after processing:", len(lemmatized_tokens))
print("Processed Tokens List:", lemmatized_tokens)
print("-" * 60)
print("Processing complete.")
print("FINAL PROCESSED TOKENS:\n", lemmatized_tokens)
print("-" * 60)
print("Total tokens after processing:", len(lemmatized_tokens))
print("Processed Tokens List:", lemmatized_tokens)
print("-" * 60)
